# === SOLANA ===
SOLANA_RPC_HTTPS=https://mainnet.helius-rpc.com/?api-key=YOUR_KEY
# Must be wss:// (not https://) — same api-key host as HTTPS is fine.
SOLANA_RPC_WSS=wss://mainnet.helius-rpc.com/?api-key=YOUR_KEY

# === TELEGRAM ===
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_chat_id_or_channel_id

# === TWITTERAPI.IO ===
TWITTER_API_IO_KEY=your_twitterapi_io_key
# Optional override if your plan uses different paths/hosts
# TWITTERAPI_IO_BASE_URL=https://api.twitterapi.io

# === WEB ===
NEXT_PUBLIC_BASE_URL=http://localhost:3000
BOT_PORT=4000
BOT_BASE_URL=http://localhost:4000

# === PUMPTX CONFIG ===
MIN_BUY_SOL=0.5
COOLDOWN_MS=10000

# Optional: timeout (ms) for Jupiter + DexScreener metadata fetches (symbol / market cap).
# METADATA_FETCH_MS=4000

# === HELIUS FREE RPC PACING (10 RPC RPS total on Free) ===
# Min delay between queued getTransaction calls (ms). Default ceil(1000/7)=143 → max ~7 req/s.
RPC_MIN_INTERVAL_MS=143
# Max unique signatures waiting in the internal fetch queue (backpressure).
RPC_QUEUE_CAP=80
# Extra sleep after a 429 / Too Many Requests response (ms).
RPC_429_BACKOFF_MS=2500
