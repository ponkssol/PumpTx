# === SOLANA ===
# One URL, or several Helius keys comma-separated (same host/path, different api-key) to spread getTransaction load.
SOLANA_RPC_HTTPS=https://mainnet.helius-rpc.com/?api-key=YOUR_KEY
# SOLANA_RPC_HTTPS=https://mainnet.helius-rpc.com/?api-key=KEY1,https://mainnet.helius-rpc.com/?api-key=KEY2,https://mainnet.helius-rpc.com/?api-key=KEY3
# One WSS URL (pairs with first HTTPS only), OR same count as HTTPS comma-list for parallel log streams (deduped).
SOLANA_RPC_WSS=wss://mainnet.helius-rpc.com/?api-key=YOUR_KEY
# Multi-WS example (order must match SOLANA_RPC_HTTPS keys 1:1):
# SOLANA_RPC_WSS=wss://mainnet.helius-rpc.com/?api-key=KEY1,wss://mainnet.helius-rpc.com/?api-key=KEY2,wss://mainnet.helius-rpc.com/?api-key=KEY3
# Optional: ignore duplicate Buy log lines across websockets within this window (ms).
# WSS_LOG_DEDUPE_MS=45000

# === TELEGRAM ===
# Commands (/start, /menu, /setting), inline settings, and group add/remove (polling) use this token:
TELEGRAM_BOT_TOKEN_GENERAL=your_general_bot_token
# Optional: @username of the general bot (no @). Ensures t.me/… Open private links work if getMe fails.
# TELEGRAM_BOT_USERNAME=YourPumpTxBot
# BUY alerts to groups/channels use this token. If unset or same as GENERAL, one bot does both.
TELEGRAM_BOT_TOKEN=your_alert_bot_token
# Official channel/supergroup (MIN_BUY_SOL). Also broadcasts to every is_active=1 group in DB (each uses its own min SOL/MCAP).
# If TELEGRAM_CHAT_ID is the same id as a registered group, that chat only uses the group’s settings.
# TELEGRAM_CHAT_ID=-1001234567890
# Enable polling so bot can detect being added/removed from groups
TELEGRAM_ENABLE_POLLING=true
# Default per-group thresholds saved when bot is added into a group
DEFAULT_GROUP_MIN_SOL=0.5
DEFAULT_GROUP_MIN_MCAP=0
# Optional hero images for private/group onboarding cards
# TELEGRAM_WELCOME_IMAGE_URL=https://your-cdn.com/telegram/welcome.jpg
# TELEGRAM_SETTING_IMAGE_URL=https://your-cdn.com/telegram/setting.jpg
# TELEGRAM_GROUP_READY_IMAGE_URL=https://your-cdn.com/telegram/group-ready.jpg

# === DISCORD (optional) ===
# Server → Channel Settings → Integrations → Webhooks → New Webhook → Copy Webhook URL
# DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/000000000000000000/xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# (Alias: DISCORD_WEBHOOK — same value if you prefer a shorter name.)
# BUY to webhook only if SOL >= (DISCORD_MIN_SOL if set, else MIN_BUY_SOL) and MCAP >= DISCORD_MIN_MCAP (default 0)
# DISCORD_MIN_SOL=0
# DISCORD_MIN_MCAP=0

# === TWITTERAPI.IO ===
TWITTER_API_IO_KEY=your_twitterapi_io_key
# Optional override if your plan uses different paths/hosts
# TWITTERAPI_IO_BASE_URL=https://api.twitterapi.io

# === WEB ===
NEXT_PUBLIC_BASE_URL=http://localhost:3000
# PostgreSQL for bot storage
DATABASE_URL=postgresql://username:password@localhost:5432/pumptx
# Header: social icons (optional — sensible defaults if unset)
# NEXT_PUBLIC_SOCIAL_TELEGRAM_URL=https://t.me/your_channel_or_bot
# NEXT_PUBLIC_SOCIAL_X_URL=https://x.com/your_handle
# NEXT_PUBLIC_SOCIAL_DISCORD_URL=https://discord.gg/your_invite
BOT_PORT=4000
BOT_BASE_URL=http://localhost:4000

# === PUMPTX CONFIG ===
MIN_BUY_SOL=0.5
COOLDOWN_MS=10000
# Share card: `disk` (default) saves PNG under apps/bot/public/generated. `memory` keeps PNG in RAM only
# (Telegram/Twitter still get the image; DB image_url stays empty so web has no stored preview).
# PUMPTX_SHARE_IMAGE_MODE=memory
# Cleanup worker runs every 10 minutes and deletes image files older than 23 hours in apps/bot/public/generated.

# Optional: timeout (ms) for Jupiter + DexScreener metadata fetches (symbol / market cap).
# METADATA_FETCH_MS=4000

# === HELIUS FREE RPC PACING (10 RPC RPS total on Free) ===
# Min delay between queued getTransaction calls (ms). Default ceil(1000/(7*N)) when N = comma-separated HTTPS URLs (each key ~7 req/s headroom).
# RPC_MIN_INTERVAL_MS=143
# Max unique signatures waiting in the internal fetch queue (backpressure).
RPC_QUEUE_CAP=80
# Extra sleep after a 429 / Too Many Requests response (ms).
RPC_429_BACKOFF_MS=2500
